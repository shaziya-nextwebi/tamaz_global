<%@ Master Language="C#" AutoEventWireup="true" CodeFile="MasterPage.master.cs" Inherits="MasterPage" %>

<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TAMAZ Global</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="assests/Images/favicon.png" />

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <!-- Site Stylesheet -->
    <link rel="stylesheet" href="style.css" />

    <style>
        /* Hide scrollbar for Chrome, Safari and Edge */
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .mobileNavDrawerMenu {
            z-index: 9999 !important;
        }
        /*      .dropdown-item
          {
              transition:0.3s ease;
          }
        .dropdown-item:hover{
            color:#0a1b50;
            transform:translateX(4px);
        }
      */
        .visible-xs {
            display: none;
        }

        @media(max-width:576px) {
            .logo-image {
                width: 100px;
            }

            .main-header.shrink .logo-image {
                width: 80px;
            }

            .whats-app-float {
                display: none !important;
            }

            .visible-xs {
                display: block;
            }

            footer {
                padding: 30px 0px 50px !important;
            }

            .search-container input {
                padding: 8px 40px 8px 24px;
                border-radius: 18px;
            }

            .search-btn {
                width: 30px;
                height: 30px;
                right: 22px;
    top: 38%;
            }
        }

        .mobile-bottom {
            width: 100%;
            position: fixed;
            bottom: -1px;
            height: auto;
            z-index: 9999;
            cursor: pointer;
        }

            .mobile-bottom ul li.call {
                padding: 8px 10px;
                background: #f00;
                /*    text-transform: uppercase;*/
                color: #fff;
                margin-left: 0;
                float: left;
                text-align: center;
                list-style: none;
                width: 50%;
                font-size: 15px;
                font-weight: 600;
            }

            .mobile-bottom ul li a {
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .mobile-bottom ul li.wtsapp {
                padding: 8px 10px;
                background: #008000;
                /*    text-transform: uppercase;*/
                color: #fff;
                margin-left: 0;
                float: left;
                text-align: center;
                list-style: none;
                width: 50%;
                font-size: 15px;
                font-weight: 600;
            }

            .mobile-bottom ul li a {
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .search-suggestions {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    z-index: 9999;
    overflow: hidden;
    display: none;
    max-height: 360px;
    overflow-y: auto;
}
.suggestion-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid #f3f4f6;
}
.suggestion-item:last-child { border-bottom: none; }
.suggestion-item:hover { background: #f9fafb; }
.suggestion-img {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    object-fit: cover;
    background: #f3f4f6;
    flex-shrink: 0;
}
.suggestion-info { display: flex; flex-direction: column; }
.suggestion-name { font-size: 13px; font-weight: 600; color: #111827; line-height: 1.3; }
.suggestion-cat { font-size: 11px; color: #9ca3af; margin-top: 2px; }
.suggestion-no-result { padding: 14px 16px; font-size: 13px; color: #9ca3af; }
.search-suggestions::-webkit-scrollbar {
    width: 4px;   /* 👈 thin */
}

.search-suggestions::-webkit-scrollbar-track {
    background: transparent;
}

.search-suggestions::-webkit-scrollbar-thumb {
    background: #bbb;
    border-radius: 10px;
}

/* On hover → slightly visible */
.search-suggestions:hover::-webkit-scrollbar-thumb {
    background: #888;
}

/* Firefox */
.search-suggestions {
    scrollbar-width: thin;
    scrollbar-color: #bbb transparent;
}
    </style>

    <!-- Page-level head content -->
    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>
<body>
    <form id="form1" runat="server">

        <!-- ===================== HEADER ===================== -->
