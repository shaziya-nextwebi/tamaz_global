        <%-- //mobile menu--%>
        <!-- Mobile Nav Overlay -->
        <div id="mobileNavOverlay" class="fixed inset-0 bg-black/40 z-40 hidden"></div>

        <!-- Mobile Nav Drawer -->
        <div id="mobileNavDrawer" class="mobileNavDrawerMenu fixed top-0 left-0 h-full w-[320px] bg-white  shadow-xl transform -translate-x-full transition-transform duration-300 flex flex-col">

            <!-- Drawer Header -->
            <div class="flex items-center justify-between px-4 py-4 border-b border-gray-200">
                <!-- Tabs -->
                <div class="flex gap-4">
                    <span id="tabCategories" class="mobile-drawer-tab active-tab font-semibold text-sm" onclick="switchTab('categories')">CATEGORIES</span>
                    <span id="tabMainMenu" class="mobile-drawer-tab text-sm text-black-500" onclick="switchTab('mainmenu') ">MAIN MENU</span>
                </div>
                <span id="closeDrawerBtn" class="p-2 hover:bg-gray-100 rounded-full">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </span>
            </div>

            <!-- Categories Tab -->
            <div id="panelCategories" class="overflow-y-auto flex-1">
                <%=strNavCategories %>
                <!-- Fallback static list (remove if strNavCategories covers all) -->
            </div>

            <!-- Main Menu Tab -->
            <div id="panelMainMenu" class="overflow-y-auto flex-1 hidden">
                <a href="/Default.aspx" class="mobile-nav-item">Home</a>
                <a href="/About.aspx" class="mobile-nav-item">About Us</a>
                <a href="/Blog.aspx" class="mobile-nav-item">Blog</a>
                <a href="/ContactUs.aspx" class="mobile-nav-item">Contact Us</a>
            </div>
        </div>
        <script>
            const dummyProducts = [
                { name: "Glutax 5GS Micro Advance", category: "Glutathione Injections", img: "/assests/Images/products/p1.png" },
                { name: "Aqua Skin Veniscy 86", category: "Glutathione Injections", img: "/assests/Images/products/p2.png" },
                { name: "Active White L-Glutathione", category: "Skin Whitening Pills", img: "/assests/Images/products/p3.png" },
                { name: "Dr James Advance Whitening Cream", category: "Skin Whitening Cream", img: "/assests/Images/products/p4.png" },
                { name: "Gluta C Intense Whitening Soap", category: "Skin Whitening Soap", img: "/assests/Images/products/p5.png" },
                { name: "Health Tone Weight Gain Capsules", category: "Weight Gain Products", img: "/assests/Images/products/p6.png" },
                { name: "Collagen Booster Injection", category: "Other Injections", img: "/assests/Images/products/p7.png" },
                { name: "Glutax 2GS Recombined White", category: "Glutathione Injections", img: "/assests/Images/products/p8.png" }
            ];

            const fallbackImg = "/assests/Images/favicon.png";

            function buildSuggestions(query, containerId) {
                const box = document.getElementById(containerId);
                if (!box) return;
                const q = query.trim().toLowerCase();
                if (!q) { box.style.display = 'none'; return; }

                const matches = dummyProducts.filter(p =>
                    p.name.toLowerCase().includes(q) || p.category.toLowerCase().includes(q)
                );

                if (matches.length === 0) {
                    box.innerHTML = `<div class="suggestion-no-result">No results found for "<strong>${query}</strong>"</div>`;
                } else {
                    box.innerHTML = matches.map(p => `
            <div class="suggestion-item" onclick="window.location='Product.aspx'">
                <img class="suggestion-img" src="${p.img}" onerror="this.src='${fallbackImg}'" alt="${p.name}" />
                <div class="suggestion-info">
                    <span class="suggestion-name">${p.name}</span>
                    <span class="suggestion-cat">${p.category}</span>
                </div>
            </div>
        `).join('');
                }
                box.style.display = 'block';
            }

            function initSearch(inputId, suggestionsId) {
                const input = document.getElementById(inputId);
                if (!input) return;
                input.addEventListener('input', () => buildSuggestions(input.value, suggestionsId));
                input.addEventListener('focus', () => { if (input.value.trim()) buildSuggestions(input.value, suggestionsId); });
            }

            initSearch('desktopSearchInput', 'desktopSuggestions');
            initSearch('mobileSearchInput', 'mobileSuggestions');

            document.addEventListener('click', function (e) {
                ['desktopSuggestions', 'mobileSuggestions'].forEach(id => {
                    const box = document.getElementById(id);
                    if (box && !box.contains(e.target) && e.target.id !== 'desktopSearchInput' && e.target.id !== 'mobileSearchInput') {
                        box.style.display = 'none';
                    }
                });
            });
        </script>

        <style>
            /* Mobile drawer tab styles */
            .mobile-drawer-tab {
                background: none;
                border: none;
                cursor: pointer;
                padding-bottom: 4px;
            }

            .active-tab {
                color: #e11d48;
                border-bottom: 2px solid #e11d48;
            }

            .mobile-nav-item {
                display: block;
                padding: 14px 20px;
                border-bottom: 1px solid #f0f0f0;
                font-size: 15px;
                color: #333;
                text-decoration: none;
            }

                .mobile-nav-item:hover {
                    background: #f9f9f9;
                }

            @media (max-width: 767px) {
                .mobile-search-bar .search-container {
                    width: 100%;
                }

                    .mobile-search-bar .search-container input {
                        width: 100%;
                    }

                .mobile-cart-icon {
                    display: flex;
                }
            }
        </style>

        <script>
            // Open / Close Drawer
            const menuBtn = document.getElementById('mobileMenuBtn');
            const overlay = document.getElementById('mobileNavOverlay');
            const drawer = document.getElementById('mobileNavDrawer');
            const closeBtn = document.getElementById('closeDrawerBtn');

            function openDrawer() {
                drawer.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function closeDrawer() {
                drawer.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
                document.body.style.overflow = '';
            }

            if (menuBtn) menuBtn.addEventListener('click', openDrawer);
            if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
            if (overlay) overlay.addEventListener('click', closeDrawer);

            // Tab switching
            function switchTab(tab) {
                const catPanel = document.getElementById('panelCategories');
                const menuPanel = document.getElementById('panelMainMenu');
                const tabCat = document.getElementById('tabCategories');
                const tabMenu = document.getElementById('tabMainMenu');

                if (tab === 'categories') {
                    catPanel.classList.remove('hidden');
                    menuPanel.classList.add('hidden');
                    tabCat.classList.add('active-tab');
                    tabCat.style.color = '#e11d48';
                    tabMenu.classList.remove('active-tab');
                    tabMenu.style.color = '#6b7280';
                } else {
                    menuPanel.classList.remove('hidden');
                    catPanel.classList.add('hidden');
                    tabMenu.classList.add('active-tab');
                    tabMenu.style.color = '#e11d48';
                    tabCat.classList.remove('active-tab');
                    tabCat.style.color = '#6b7280';
                }
            }
        </script>

    </form>

    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <!-- Sticky Header Script -->
    <script>
        const header = document.querySelector(".main-header");
        let headerHeight = header.offsetHeight;

        window.addEventListener("resize", () => {
            if (!header.classList.contains("sticky")) {
                headerHeight = header.offsetHeight;
            }
        });

        window.addEventListener("scroll", () => {
            if (window.scrollY > 10) {
                if (!header.classList.contains("sticky")) {
                    headerHeight = header.offsetHeight;
                    document.body.style.paddingTop = headerHeight + "px";
                    header.classList.add("sticky", "shrink");
                }
            } else {
                if (header.classList.contains("sticky")) {
                    header.classList.remove("sticky", "shrink");
                    document.body.style.paddingTop = "0px";
                }
            }
        });
    </script>

    <!-- Page-level scripts placeholder -->
    <asp:ContentPlaceHolder ID="scripts" runat="server">
    </asp:ContentPlaceHolder>

</body>
